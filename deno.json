{
  "tasks": {
    "dev": "deno task install-hooks && deno run --env-file=.env.local --allow-env --allow-net --allow-read --watch src/server.tsx",
    "start": "deno run --cached-only --allow-env=ENV,NAIS_CLUSTER_NAME,HENDELSELOGG_BACKUP_URL,OPPSLAG_API_V2_URL,NAIS_TOKEN_ENDPOINT,NAIS_TOKEN_EXCHANGE_ENDPOINT,NAIS_TOKEN_INTROSPECTION_ENDPOINT,TOKEN_X_ISSUER,AZURE_OPENID_CONFIG_ISSUER,TZ,OTEL_EXPORTER_OTLP_ENDPOINT,OTEL_SERVICE_NAME,OTEL_RESOURCE_ATTRIBUTES --allow-net --allow-read=./static src/server.tsx",
    "check": "deno check --unstable-tsgo .",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "install-hooks": "git config core.hooksPath .githooks",
    "outdated": "deno outdated --minimum-dependency-age P7D"
  },
  "imports": {
    "@/": "./src/",
    "@/views/": "./views/",
    "@navikt/aksel-icons": "npm:@navikt/aksel-icons@8.9.0",
    "@navikt/arbeidssokerregisteret-utils": "npm:@navikt/arbeidssokerregisteret-utils@2.1.0",
    "@navikt/oasis": "npm:@navikt/oasis@4.1.4",
    "hono": "jsr:@hono/hono@4.12.12"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "lint": {
    "include": ["src/", "views/", "static/app.js"]
  },
  "fmt": {
    "include": ["src/", "views/", "static/app.js", "static/stylesheet.css"]
  }
}
