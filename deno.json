{
  "tasks": {
    "dev": "deno task install-hooks && deno run --env-file=.env.local --allow-env --allow-net --allow-read --watch src/server.tsx",
    "start": "deno run  --cached-only --allow-env --allow-net --allow-read src/server.tsx",
    "check": "deno check --unstable-tsgo .",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "install-hooks": "git config core.hooksPath .githooks"
  },
  "imports": {
    "@/": "./src/",
    "@/views/": "./views/",
    "@navikt/aksel-icons": "npm:@navikt/aksel-icons@^8.1.0",
    "@navikt/arbeidssokerregisteret-utils": "npm:@navikt/arbeidssokerregisteret-utils@^1.9.2",
    "@navikt/oasis": "npm:@navikt/oasis@^4.1.1",
    "hono": "jsr:@hono/hono@^4.10.8"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "lint": {
    "include": ["src/", "views/", "static/app.js"]
  },
  "fmt": {
    "include": ["src/", "views/", "static/app.js", "static/stylesheet.css"]
  }
}
